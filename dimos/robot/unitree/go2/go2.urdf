<?xml version="1.0"?>
<robot name="go2">
  <!-- Base link: center of robot body -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.7 0.31 0.4"/>
      </geometry>
      <material name="box_material">
        <color rgba="0.0 0.0 0.0 0.2"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.7 0.31 0.4"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="15.0"/>
      <inertia ixx="0.320125" ixy="0" ixz="0" iyy="0.812500" iyz="0" izz="0.732625"/>
    </inertial>
  </link>

  <!-- Livox Mid-360 on Unitree official expansion dock -->
  <!-- Official mount pose from Unitree SDK2 docs (2026-01-20): -->
  <!-- Translation: (0.1870, 0, 0.0803) in body IMU frame -->
  <!-- Rotation: 13° around Y-axis (pitch) -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <box size="0.088 0.076 0.065"/>
      </geometry>
      <material name="lidar_material">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.088 0.076 0.065"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.265"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Fixed joint: official Unitree expansion dock mount pose -->
  <joint name="base_to_lidar" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.1870 0.0 0.0803" rpy="0.0 0.226893 0.0"/>
  </joint>
</robot>
